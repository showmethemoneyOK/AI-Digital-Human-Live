# AI数字人直播系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 平台配置 ====================

# 抖音配置
DOUYIN_APP_ID=your_douyin_app_id
DOUYIN_APP_SECRET=your_douyin_app_secret
DOUYIN_ROOM_ID=your_live_room_id

# TikTok配置
TIKTOK_APP_ID=your_tiktok_app_id
TIKTOK_APP_SECRET=your_tiktok_app_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_ROOM_ID=your_live_room_id
WEBHOOK_SECRET=your_webhook_secret
WEBHOOK_URL=https://your-domain.com/tiktok/webhook

# ==================== AI服务配置 ====================

# AI模型选择: tongyi, doubao, deepseek, gpt, claude
AI_MODEL=deepseek
AI_API_KEY=your_ai_api_key

# 可选: 自定义API URL
# AI_API_URL=https://api.deepseek.com/chat/completions

# ==================== TTS服务配置 ====================

# TTS提供商选择: aliyun, tencent, xunfei, elevenlabs
TTS_PROVIDER=aliyun
TTS_API_KEY=your_tts_api_key
TTS_APP_ID=your_tts_app_id  # 阿里云/讯飞需要
TTS_API_SECRET=your_tts_api_secret  # 腾讯云需要

# 语音配置
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_SPEED=1.0
TTS_PITCH=0
TTS_VOLUME=1.0
TTS_LANGUAGE=zh-CN

# ==================== 数字人配置 ====================

# 数字人提供商: guiji, youliao, heygen, d-id
DIGITAL_HUMAN_PROVIDER=guiji
DIGITAL_HUMAN_API_KEY=your_digital_human_api_key
DIGITAL_HUMAN_API_URL=https://api.guiji.ai/v1
DIGITAL_HUMAN_AVATAR_ID=your_avatar_id
DIGITAL_HUMAN_AVATAR_NAME=AI主播

# 输出配置
DIGITAL_HUMAN_OUTPUT_MODE=rtmp  # rtmp, virtual_camera, file
DIGITAL_HUMAN_OUTPUT_URL=rtmp://localhost/live/stream
DIGITAL_HUMAN_VIRTUAL_CAMERA=AI Digital Human

# ==================== 系统配置 ====================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 性能配置
MAX_CONCURRENT_REQUESTS=5
MAX_RESPONSE_TIME_MS=600
HEARTBEAT_INTERVAL=300

# 缓存配置
TTS_CACHE_ENABLED=true
TTS_CACHE_DIR=cache/tts
TTS_CACHE_MAX_SIZE=100

# ==================== 合规配置 ====================

# AI身份标注
AI_DISCLOSURE_REQUIRED=true
AI_DISCLOSURE_TEXT=本直播间由AI数字人主播为您服务
AI_DISCLOSURE_INTERVAL=600

# 内容过滤
CONTENT_FILTER_ENABLED=true
MAX_RESPONSE_LENGTH=100

# 敏感词（用逗号分隔）
SENSITIVE_WORDS=政治敏感词,违规词,违禁词

# TikTok特定
HUMAN_INTERACTION_REQUIRED=true
HUMAN_INTERVAL_MINUTES=15

# ==================== 商品知识库 ====================

# 当前促销
CURRENT_PROMO=全场商品7折起，满300包邮！

# 物流信息
SHIPPING_INFO=全国包邮，3-5个工作日送达
RETURN_POLICY=7天无理由退货

# ==================== 开发配置 ====================

# 测试模式
TEST_MODE=false
MOCK_API_RESPONSES=false

# 调试
DEBUG_WEBHOOK=false
LOG_REQUESTS=false

# ==================== 注意 ====================
# 1. 实际部署时，建议将敏感信息存储在安全的配置管理服务中
# 2. 不要将 .env 文件提交到版本控制系统
# 3. 生产环境使用环境变量而非文件存储敏感信息
# 4. 定期轮换API密钥